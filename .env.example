# CT产业情报Agent 环境变量模板
#
# 使用方式：
# 1. 复制本文件为 .env
# 2. 至少填写一个 LLM API Key
# 3. 如需网页全文增强，可填写 Jina Reader API Key

# ===== LLM配置（至少配置一个）=====
LLM__DEEPSEEK_API_KEY=your_deepseek_api_key
LLM__DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

LLM__QWEN_API_KEY=
LLM__QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

LLM__KIMI_API_KEY=
LLM__KIMI_BASE_URL=https://api.moonshot.cn/v1

LLM__CLAUDE_API_KEY=
LLM__CLAUDE_BASE_URL=https://api.anthropic.com/v1

LLM__DEFAULT_MODEL=deepseek-chat

# ===== 采集配置 =====
COLLECTOR__HTTP_PROXY=
COLLECTOR__HTTPS_PROXY=
COLLECTOR__JINA_API_KEY=your_jina_api_key
COLLECTOR__SERPER_API_KEY=your_serper_api_key
COLLECTOR__SEARCH_PROVIDER=serper

# 搜索采集开关。默认使用 Serper API。
COLLECTOR__ENABLE_SEARCH=true
COLLECTOR__SEARCH_MAX_QUERIES=0
COLLECTOR__SEARCH_MAX_RESULTS_PER_QUERY=10
COLLECTOR__SEARCH_PER_QUERY_TIMEOUT=30

# 企业官网采集。WEB_MAX_SITES=0 表示扫描全部官网；单站超时越大越完整但整体耗时越长。
COLLECTOR__ENABLE_WEB=true
COLLECTOR__WEB_MAX_SITES=0
COLLECTOR__WEB_PER_SITE_TIMEOUT=30

# 专利采集开关。无 EPO Key 时会使用公开搜索页面兜底采集专利线索。
COLLECTOR__ENABLE_PATENT=true
COLLECTOR__EPO_KEY=
COLLECTOR__EPO_SECRET=
# PATENT_MAX_QUERIES=0 表示执行全部默认专利查询。
COLLECTOR__PATENT_MAX_QUERIES=0
COLLECTOR__PATENT_MAX_RESULTS_PER_QUERY=5
COLLECTOR__PATENT_PER_QUERY_TIMEOUT=30

# ===== 分发配置 =====
DISTRIBUTION__SMTP_SERVER=
DISTRIBUTION__SMTP_PORT=587
DISTRIBUTION__SMTP_USER=
DISTRIBUTION__SMTP_PASSWORD=
DISTRIBUTION__SMTP_USE_TLS=true
DISTRIBUTION__EMAIL_RECIPIENTS=
DISTRIBUTION__EMAIL_SENDER=
DISTRIBUTION__ENABLE_EMAIL=false

DISTRIBUTION__WECHAT_WEBHOOK_URL=
DISTRIBUTION__ENABLE_WECHAT=false

# ===== 定时调度 =====
SCHEDULE__DAY_OF_WEEK=fri
SCHEDULE__HOUR=9
SCHEDULE__MINUTE=0

# ===== Agent增强 =====
ENABLE_REACT=true
ENABLE_CRITIC=true
ENABLE_PLANNING=true

# ===== 官网试用版联系方式 =====
# 用于 trial_demo_app.py 生成试用报告末尾的咨询引导
TRIAL__CONTACT_NAME=薄云咨询产业情报团队
TRIAL__CONTACT_PHONE=
TRIAL__CONTACT_WECHAT=
TRIAL__CONTACT_EMAIL=
